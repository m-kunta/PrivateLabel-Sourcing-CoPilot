# PL Sourcing Co-Pilot — Environment Variables
# Copy this file to .env and fill in your keys:
#   cp .env.example .env

# --- Pinecone (optional) ---
# Omit PINECONE_API_KEY to run in heuristic fallback mode (no vector DB required).
PINECONE_API_KEY=your_pinecone_key_here
PINECONE_INDEX_NAME=pl-sourcing-copilot

# --- LLM Provider ---
# Choose one: Anthropic | OpenAI | Gemini | Groq | Ollama
LLM_PROVIDER=Anthropic

# --- LLM API Keys ---
# Provide the key for whichever provider you selected above.
# Ollama runs locally and requires no key.
ANTHROPIC_API_KEY=your_anthropic_key_here
OPENAI_API_KEY=your_openai_key_here
GEMINI_API_KEY=your_gemini_key_here
GROQ_API_KEY=your_groq_key_here
